upstream aurora_backend {
    server 127.0.0.1:{{ app_port | default(80) }};
    keepalive 32;
}

server {
    listen {{ app_port | default(80) }} default_server;
    listen [::]:{{ app_port | default(80) }} default_server;
    server_name _;

    root /var/www/html;
    index index.html;

    # Character set
    charset utf-8;

    # Logging
    access_log /var/log/nginx/aurora-access.log;
    error_log  /var/log/nginx/aurora-error.log;

    # Security headers
    include snippets/security-headers.conf;

    # Gzip
    include snippets/gzip.conf;

    # Rate limiting
    limit_req zone=basic burst=20 nodelay;
    limit_conn addr 50;

    # Health check endpoint (no rate limit)
    location /health {
        access_log off;
        alias /var/www/html/health;
        default_type application/json;
        add_header Cache-Control no-store;
        add_header X-VM-Hostname "{{ ansible_hostname }}" always;
    }

    # Main location block
    location / {
        try_files $uri $uri/ =404;
        add_header X-VM-Hostname "{{ ansible_hostname }}" always;
        add_header X-Environment "{{ environment }}" always;
    }

    # Deny access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Deny access to sensitive files
    location ~ (\.env|\.git|\.htaccess|wp-config\.php) {
        deny all;
        return 404;
    }

    # Static file caching
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }
}
